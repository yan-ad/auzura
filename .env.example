# Microsoft Entra app registration for Azure DevOps OAuth.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:3000/api/auth/azure/callback
AZURE_DEVOPS_ORGANIZATION=

# MongoDB Atlas cache for dashboard metrics.
MONGODB_URI=
# Optional database name, defaults to auzura.
# MONGODB_DB=auzura

# Required by nuxt-auth-utils to encrypt the session cookie.
# Must be at least 32 characters and set in production/Vercel.
NUXT_SESSION_PASSWORD=
