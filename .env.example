# Azure DevOps organization slug, e.g. https://dev.azure.com/<organization>
# Browser-readable so the UI can show current org metadata if needed.
NUXT_PUBLIC_AZURE_DEVOPS_ORGANIZATION=

# Optional server-only alias. Useful on hosts where you prefer not to expose the org slug as public config.
# AZURE_DEVOPS_ORGANIZATION=

# Microsoft Entra app registration for Azure DevOps OAuth.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:3000/api/auth/azure/callback

# Required by nuxt-auth-utils to encrypt the session cookie.
# Must be at least 32 characters and set in production/Vercel.
NUXT_SESSION_PASSWORD=
