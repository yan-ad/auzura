# Azure DevOps organization slug, e.g. https://dev.azure.com/<organization>
# Browser-readable so the UI can show current org metadata if needed.
NUXT_PUBLIC_AZURE_DEVOPS_ORGANIZATION=

# Optional server-only alias. Useful on hosts where you prefer not to expose the org slug as public config.
# AZURE_DEVOPS_ORGANIZATION=

# Personal Access Token with Work Items read/write scope.
# Keep this server-only. Never expose it with NUXT_PUBLIC_.
NUXT_AZURE_DEVOPS_TOKEN=

# Optional shorter server-only alias.
# AZURE_DEVOPS_TOKEN=
